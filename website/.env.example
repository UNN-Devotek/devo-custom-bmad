# Arcwright website environment variables
# Copy to .env.local for local development overrides

# GitHub repository URL (used for links)
VITE_GITHUB_REPO_URL=https://github.com/UNN-Devotek/Arcwright-AI

# GitHub raw README URL (fetched live on page load)
VITE_GITHUB_RAW_README=https://raw.githubusercontent.com/UNN-Devotek/Arcwright-AI/main/README.md

# npm package URL (used for badge links)
VITE_NPM_PACKAGE_URL=https://www.npmjs.com/package/@arcwright-ai/agent-orchestration
